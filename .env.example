FS_DATABASE_URL=postgresql+psycopg://fserver:fserver@db:5432/fserver
FS_STORAGE__BACKEND=s3
FS_STORAGE__ENDPOINT=http://minio:9000
FS_STORAGE__PUBLIC_BASE_URL=http://127.0.0.1:9000
FS_STORAGE__BUCKET=f-server
FS_STORAGE__REGION=us-east-1
FS_STORAGE__ACCESS_KEY=minioadmin
FS_STORAGE__SECRET_KEY=minioadmin
FS_REPO__NAME=f-server
FS_REPO__DESCRIPTION=Private F-Droid repository
FS_REPO__URL=http://localhost:8000/repo
FS_REPO__KEYSTORE_PATH=/var/lib/f-server/keystore/repo-keystore.p12
FS_REPO__KEYSTORE_PASS=change-me
FS_REPO__KEY_ALIAS=f-server
FS_REPO__KEY_PASS=change-me
FS_ADMIN_AUTH__MODE=none
FS_ADMIN_AUTH__SESSION_SECRET=change-me
FS_UPLOADS__VERIFY_SIGNING_KEYS=true
# FS_NOTIFICATIONS__DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
FS_NOTIFICATIONS__DISCORD_USERNAME=f-server
FS_NOTIFICATIONS__DISCORD_TIMEOUT_SECONDS=5.0
